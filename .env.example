# Required
export POSTNEST_SECURITY_SESSION_KEY=change-me-in-production
export POSTNEST_POSTMARK_WEBHOOK_SECRET=your-postmark-secret

# Database (used by compose to set postgres env + app DSN)
export POSTNEST_DATABASE_PASSWORD=changeme

# Full DSN for CLI tools (admin, migrate) when NOT using docker compose networking
# For Docker Compose, get the postgres container IP:
#   export POSTNEST_DATABASE_DSN="postgres://postnest:${POSTNEST_DATABASE_PASSWORD}@$(docker inspect go-postnest-postgres-1 --format '{{range .NetworkSettings.Networks}}{{.IPAddress}}{{end}}'):5432/postnest?sslmode=disable"
# For local development:
# export POSTNEST_DATABASE_DSN=postgres://postnest:changeme@localhost:5432/postnest?sslmode=disable

# TLS (optional — mount host paths)
# export POSTNEST_TLS_CERT_PATH=/path/to/cert.pem
# export POSTNEST_TLS_KEY_PATH=/path/to/key.pem
