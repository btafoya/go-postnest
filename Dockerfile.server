FROM golang:1.25-alpine AS builder
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-w -s" -o postnest-server ./cmd/server
# Pre-create cert directory with nonroot ownership for final stage.
RUN mkdir -p /var/lib/postnest/certs && chown 65532:65532 /var/lib/postnest/certs

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /build/postnest-server /usr/local/bin/postnest-server
COPY --from=builder --chown=65532:65532 /var/lib/postnest/certs /var/lib/postnest/certs
EXPOSE 8080 143 587 993 465
ENTRYPOINT ["/usr/local/bin/postnest-server"]
